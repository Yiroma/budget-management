DB_NAME=your_db_name
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_PORT=5432

# Clé secrète JWT — générer une clé Base64 aléatoire d'au moins 32 octets
# Exemple : openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
# Durée de validité du token en millisecondes (défaut : 86400000 = 24h)
JWT_EXPIRATION=86400000
